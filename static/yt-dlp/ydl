#!/usr/bin/env bash

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/yt-dlp"

usage() {
    echo "Usage:"
    echo "  ydl [profile] <URL> [yt-dlp options]"
    echo
    echo "Examples:"
    echo "  ydl music <URL>        -- use config.music"
    echo "  ydl <URL>              -- use default config"
    echo
    echo "Available profiles:"
    shopt -s nullglob
    for f in "$CONFIG_DIR"/config.*; do
        echo "  $(basename "$f")"
    done
    shopt -u nullglob
    echo
    echo "Hint: use the -P parameter to specify a output directory."
}

# If no arguments, show usage
if [ $# -eq 0 ]; then
    usage
    exit 0
fi

# Check if first argument looks like a URL (contains "://")
if [[ "$1" == *"://"* ]]; then
    exec yt-dlp --config-location "$CONFIG_DIR/config" "$@"
fi

# First argument is a profile name
PROFILE="$1"
CONFIG_FILE="$CONFIG_DIR/config.$PROFILE"

# Check the profile config file exists
if [ ! -f "$CONFIG_FILE" ]; then
    echo "[ERROR] Profile \"$PROFILE\" not found." >&2
    echo "        Expected: $CONFIG_FILE" >&2
    echo >&2
    echo "Available profiles:" >&2
    shopt -s nullglob
    for f in "$CONFIG_DIR"/config.*; do
        echo "  $(basename "$f")" >&2
    done
    shopt -u nullglob
    exit 1
fi

# Drop the first argument (the profile name) and pass the rest through
shift
exec yt-dlp --config-location "$CONFIG_FILE" "$@"
